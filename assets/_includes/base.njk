<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} - OSPedia</title>
  <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet">
  <link href="/global/stylesheets/fluent-ui-light.css" rel="stylesheet" id="setSs" />

  {% if tags and "demo-pages" in tags %}
  <link rel="stylesheet" href="/global/stylesheets/demos-light.css" id="setDemoSs" />
  {% elif tags and "homepages" in tags and page.url != "/" %}
  <link rel="stylesheet" href="/global/stylesheets/homepage-styles.css" />
  {% elif page.url == "/" %}
  <link rel="stylesheet" href="/global/stylesheets/index-page-styles-light.css" id="setIndexSs" />
  {% endif %}

  <script src="/pagefind/pagefind-component-ui.js" type="module"></script>
  <script src="/themes.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
    rel="stylesheet" />
  <link rel="icon" href="/global/OSPedia-favicon.svg" />
</head>

{% if page.url == "/" %}
{% set style = "background-image: url(\"/global/OSPedia-background.svg\")" %}
{% elif tags and "homepages" in tags %}
{% set style = "background-image: url(\"" ~ background_image ~ "\")" %}
{% elif tags and "windows-pages" in tags or "macos-pages" in tags or "ubuntu-pages" in tags %}
{% set style = "background-image: url(\"./" ~ background_image ~ "\")" %}
{% elif background_image %}
{% set style = "background-image: url(\"" ~ background_image ~ "\")" %}
{% endif %}

<body style="{{ style }}">
  {% include "_nav.njk" %}
  {% raw %}
  <div class="pagefind-container">
    <pagefind-results show-images hide-sub-results>
      <script type="text/pagefind-template">
    <li class="pf-result">
      <div class="pf-result-card">
        {{#if and(options.show_images, meta.image)}}
        <img class="pf-result-image" src="{{ meta.image | resolveUrl(meta.url | default(url)) }}" alt="{{ meta.image_alt | default(meta.title) }}">
        {{/if}}
        <div class="pf-result-content">
          <p class="pf-result-title">
            <a class="pf-result-link" href="{{ meta.url | default(url) | safeUrl }}"{{#if options.link_target}} target="{{ options.link_target }}"{{/if}}{{#if eq(options.link_target, "_blank")}} rel="noopener"{{/if}}>{{ meta.title }}</a>
          </p>
          {{#if excerpt}}
          <p class="pf-result-excerpt">{{+ excerpt +}}</p>
          {{/if}}
        </div>
      </div>
    </li>
  </script>
      <script type="text/pagefind-template" data-template="placeholder">
    <li class="pf-result" aria-hidden="true">
      <div class="pf-result-card">
        <div class="pf-skeleton pf-skeleton-image"></div>
        <div class="pf-result-content">
          <p class="pf-result-title pf-skeleton pf-skeleton-title"></p>
          <p class="pf-result-excerpt pf-skeleton pf-skeleton-excerpt"></p>
        </div>
      </div>
    </li>
  </script>
    </pagefind-results>
  </div>
  {% endraw %}
  <div class="wrapper">
    <div class="contents">
      <h2 id="toc">Contents</h2>
      <noscript>Enable JavaScript for the best experience!</noscript>
      <img src="/global/Images/close.png" alt="Close button" class="contents-close" />
    </div>
    {% if tags and "win-demo-pages" in tags %}
    {% include "_windows-demo-partial.njk" %}
    {% elif tags and "mac-demo-pages" in tags %}
    <main data-pagefind-ignore>
      <h1>{{ title }}</h1>
      {{ content | safe }}
    </main>
    {% else %}
    <main>
      {% if tags and not "homepages" in tags %}
      <h1 id="heading" data-pagefind-weight="10">{{ title }}</h1>
      {% endif %}
      {{ content | splitContent(0) | safe }}
      {% if favicon and paras %}
      <div class="info">
        <img src="{{ page.url | parentFolder }}/{{ favicon }}" alt="{{ info.icon[0].alt }}" />
        {% for para in info.paras %}
        <p>{{ para | safe}}</p>
        {% endfor %}
      </div>
      {% endif %}
      {{ content | splitContent(1) | safe }}
      {% include "_footer.njk" %}
    </main>
    {% endif %}
    <div class="extras">
      {% if carousel_images %}
      <h2>Carousel</h2>
      <button class="carousel-open">Open Carousel</button>
      {% endif %}
      {% if tags and not "homepages" in tags %}
      {% include "_page-nav.njk" %}
      {% endif %}
      <section class="fun-fact">
        <h2>Did you know?</h2>
        <p class="fun-fact"></p>
      </section>
    </div>

    {% if carousel_images %}
    <section class="carousel-wrapper hidden">
      <div class="carousel">
        {% for image in carousel_images %}
        <figure>
          <a href="{{ image.path }}" target="_blank">
            <img src="{{ image.path }}" alt="{{ image.alt }}" class="carousel-image" />
          </a>
          <figcaption>{{ image.desc }}</figcaption>
        </figure>
        {% endfor %}
      </div>
      <img src="/global/Images/close.png" alt="Close button" class="carousel-close" />
      <div class="carousel-prev"></div>
      <div class="carousel-next"></div>
    </section>
    <div class="carousel-backdrop hidden"></div>
    {% endif %}
  </div>

  <div class="bar">
    <div class="bottom-bar">
      <div class="back-to-top"></div>
      <div class="carousel-button" data-opens-element="carousel"></div>
      <div class="contents-button" data-opens-element="div.contents"></div>
      <div class="did-you-know-button" data-opens-element="section.fun-fact"></div>
    </div>

    <div class="pagefind-blur"></div>

    {% set current_collection = null %}
    {% if tags and "windows-pages" in tags %}
    {% set current_collection = collections['windows-pages'] %}
    {% elif tags and "macos-pages" in tags %}
    {% set current_collection = collections['macos-pages'] %}
    {% endif %}

    {% if current_collection != null %}
    {% set prev_page = current_collection | getPreviousCollectionItem(page) %}
    {% set next_page = current_collection | getNextCollectionItem(page) %}

    {% if prev_page %}
    <div>
      <a href="{{ prev_page.url }}">
        <img src="../{{ prev_page.fileSlug }}/{{ prev_page.data.favicon }}" alt="Previous page">
      </a>
    </div>
    {% endif %}

    {% if next_page %}
    <div>
      <a href="{{ next_page.url }}">
        <img src="../{{ next_page.fileSlug }}/{{ next_page.data.favicon }}" alt="Next page">
      </a>
    </div>
    {% endif %}

    {% endif %}
  </div>

  {% if tags and "macos-pages" in tags %}
  <template>
    <tr>
      <td class="left version"></td>
      <td class="build"></td>
      <td class="release-date"></td>
      <td class="darwin-version"></td>
      <td class="right release-notes"></td>
    </tr>
  </template>
  <script src="/macos/tables.js"></script>
  {% endif %}

  <script src="/script.js"></script>
  <script src="/fun-fact.js"></script>

  {% if carousel_images %}
  <script src="/carousel.js"></script>
  {% endif %}

  {% if tags and "win-demo-pages" in tags %}
  <script src="./libv86.js"></script>
  <script>
    window.disk = "{{ disk }}";
    window.imagePath = "{{ url }}";
  </script>
  <script src="./demos.js"></script>
  {% endif %}
  <script src="/bottom-bar.js"></script>
</body>

</html>
